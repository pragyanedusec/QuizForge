PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/quiz_service_db?retryWrites=true&w=majority
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change_this_to_a_strong_secret

# Redis (BullMQ queue for PDF processing)
# Option A — single URL (Upstash, Railway, Render):
# REDIS_URL=rediss://:<password>@<host>:6379
# Option B — individual vars (local Redis):
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
